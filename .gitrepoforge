name: badgeindexer
default_branch: main
config:
  description: "Collects README badges across an organization and generates a structured dashboard with per-repo and per-badge detail pages."
  license: MIT
  language: go
  release: release-go
  justfile: true
  gitignore: [
    "badges.json",
    "data/",
    "output/"
  ]
  clip4llm:
    exclude: [
      "data",
      "output"
    ]
